rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Readings - only owner can access
    match /readings/{readingId} {
      allow read: if request.auth != null && resource.data.userId == request.auth.uid;
      allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;
      allow update, delete: if request.auth != null && resource.data.userId == request.auth.uid;
    }
    
    // Custom Lists
    match /customLists/{listId} {
      // Public/Link or Owner access
      allow read: if resource.data.visibility != 'private' || (request.auth != null && resource.data.userId == request.auth.uid);
      // Create requires auth and matching userId
      allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;
      // Update: owner cualquier campo. Cualquier auth si SOLO cambia likesCount
      // (para que el toggleLike funcione desde otros usuarios). En ningun caso
      // se acepta un likesCount negativo.
      allow update: if request.auth != null
        && request.resource.data.likesCount >= 0
        && (
          resource.data.userId == request.auth.uid ||
          request.resource.data.diff(resource.data).affectedKeys().hasOnly(['likesCount'])
        );
      allow delete: if request.auth != null && resource.data.userId == request.auth.uid;
      
      // Likes subcollection - auth required
      match /likes/{likeId} {
        allow read: if true;
        allow write: if request.auth != null;
      }
      
      // Comments subcollection - auth required to write
      match /comments/{commentId} {
        allow read: if true;
        allow create: if request.auth != null;
        allow delete: if request.auth != null && resource.data.userId == request.auth.uid;
      }
    }

    // Users collection
    match /users/{userId} {
      allow read: if request.auth != null;

      // Create permitido para el owner (registro de cuenta).
      allow create: if request.auth != null && request.auth.uid == userId;

      // Update: el owner puede cambiar cualquier campo, EXCEPTO el username
      // que tiene cooldown de 30 dias. Si username no cambia, sin restriccion.
      // Si username cambia, debe ser el primer cambio (no hay
      // usernameChangedAt previo) o haber pasado el cooldown.
      allow update: if request.auth != null && request.auth.uid == userId
        && (
          !('username' in request.resource.data) ||
          request.resource.data.username == resource.data.username ||
          !('usernameChangedAt' in resource.data) ||
          request.time > resource.data.usernameChangedAt + duration.value(30, 'd')
        );

      // Delete: no permitido. Eliminar cuenta requeriria cascade (lecturas,
      // posts, listas, amistades) -> Cloud Function. Out of scope.

      // Friends subcollection
      match /friends/{friendId} {
        allow read: if request.auth != null;
        // Allow write if user is owner of the profile OR the friend being added (for reciprocal adds)
        allow write: if request.auth != null && (request.auth.uid == userId || request.auth.uid == friendId);
      }
    }

    // Friend Requests
    match /friend_requests/{requestId} {
      allow create: if request.auth != null && request.resource.data.fromUserId == request.auth.uid;
      allow read: if request.auth != null && (resource.data.fromUserId == request.auth.uid || resource.data.toUserId == request.auth.uid);
      allow update: if request.auth != null && (resource.data.fromUserId == request.auth.uid || resource.data.toUserId == request.auth.uid);
      allow delete: if request.auth != null && (resource.data.fromUserId == request.auth.uid || resource.data.toUserId == request.auth.uid);
    }

    // Notifications
    match /notifications/{notificationId} {
      allow read: if request.auth != null && resource.data.userId == request.auth.uid;
      allow create: if request.auth != null;
      allow update: if request.auth != null && resource.data.userId == request.auth.uid;
      allow delete: if request.auth != null && resource.data.userId == request.auth.uid;
    }

    // Usernames collection (public read for uniqueness check and login)
    match /usernames/{username} {
      allow read: if true;
      // Allow create if user is reserving for themselves
      allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;
      // Allow update if owner (para sincronizar el campo `email` cuando el
      // usuario cambia su email via verifyBeforeUpdateEmail). El userId no se
      // puede modificar — sigue ligando username -> uid.
      allow update: if request.auth != null
        && resource.data.userId == request.auth.uid
        && request.resource.data.userId == resource.data.userId;
      // Allow delete if owner (e.g. strict cleanup, though app doesn't implement delete yet)
      allow delete: if request.auth != null && resource.data.userId == request.auth.uid;
    }
    
    // Collection group para comentarios de posts. Permite collection group
    // queries (ej. listar comentarios de un usuario en su perfil publico) sin
    // que Firestore las rechace. Funciona solo con comentarios que tienen
    // postAuthorId denormalizado (los nuevos). Los antiguos siguen siendo
    // legibles via la regla path-specifica de abajo.
    match /{path=**}/comments/{commentId} {
      allow read: if request.auth != null
        && resource.data.postAuthorId != null
        && (
          resource.data.postAuthorId == request.auth.uid
          || exists(/databases/$(database)/documents/users/$(request.auth.uid)/friends/$(resource.data.postAuthorId))
        );
    }

    // Posts (Home feed)
    match /posts/{postId} {
      function isAuthor() {
        return request.auth != null && resource.data.authorId == request.auth.uid;
      }
      function isFriendOfAuthor() {
        return request.auth != null && exists(
          /databases/$(database)/documents/users/$(request.auth.uid)/friends/$(resource.data.authorId)
        );
      }
      function canViewPost() {
        return isAuthor() || isFriendOfAuthor();
      }

      // Read: el autor o un amigo del autor (existe en su subcoleccion friends).
      allow read: if canViewPost();
      // Create: solo si el autor es el usuario autenticado.
      allow create: if request.auth != null && request.resource.data.authorId == request.auth.uid;
      // Delete: solo el autor.
      allow delete: if isAuthor();
      // Update: el autor (cualquier campo) o cualquier auth si solo cambian counters
      // (likesCount/commentsCount/repostsCount). Permite increments via transaction.
      // Los counters nunca pueden ser negativos.
      allow update: if request.auth != null
        && request.resource.data.likesCount >= 0
        && request.resource.data.commentsCount >= 0
        && request.resource.data.repostsCount >= 0
        && (
          isAuthor() ||
          (canViewPost() && request.resource.data.diff(resource.data).affectedKeys()
            .hasOnly(['likesCount', 'commentsCount', 'repostsCount']))
        );

      // Likes en el post: cualquier lector del post puede ver. Solo puedes
      // crear/borrar tu propio like (likeId == auth.uid).
      match /likes/{userId} {
        function canSeePost() {
          let post = get(/databases/$(database)/documents/posts/$(postId)).data;
          return request.auth != null && (
            post.authorId == request.auth.uid ||
            exists(/databases/$(database)/documents/users/$(request.auth.uid)/friends/$(post.authorId))
          );
        }
        allow read: if canSeePost();
        allow create: if request.auth != null && userId == request.auth.uid && canSeePost();
        allow delete: if request.auth != null && userId == request.auth.uid;
      }

      // Comentarios: cualquier lector del post puede ver y comentar. Borrar:
      // el autor del comentario o el autor del post.
      match /comments/{commentId} {
        function postData() {
          return get(/databases/$(database)/documents/posts/$(postId)).data;
        }
        function canSeePost() {
          let post = postData();
          return request.auth != null && (
            post.authorId == request.auth.uid ||
            exists(/databases/$(database)/documents/users/$(request.auth.uid)/friends/$(post.authorId))
          );
        }
        allow read: if canSeePost();
        allow create: if request.auth != null
          && request.resource.data.userId == request.auth.uid
          && canSeePost();
        // Solo el autor del comentario puede borrarlo, incluso si el post es de otro.
        allow delete: if request.auth != null && resource.data.userId == request.auth.uid;
      }

      // Markers de reposts: cualquier lector del post puede ver. Solo puedes
      // crear/borrar tu propio marker (userId == auth.uid).
      match /reposts/{userId} {
        function canSeePost() {
          let post = get(/databases/$(database)/documents/posts/$(postId)).data;
          return request.auth != null && (
            post.authorId == request.auth.uid ||
            exists(/databases/$(database)/documents/users/$(request.auth.uid)/friends/$(post.authorId))
          );
        }
        allow read: if canSeePost();
        allow create: if request.auth != null && userId == request.auth.uid && canSeePost();
        allow delete: if request.auth != null && userId == request.auth.uid;
      }
    }

    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
