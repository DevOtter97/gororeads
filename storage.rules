rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {

    // Avatares de usuario: cualquier usuario auth puede leer; solo el dueño escribe.
    match /avatars/{userId}/{allPaths=**} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
        && request.auth.uid == userId
        && request.resource.size < 5 * 1024 * 1024
        && request.resource.contentType.matches('image/.*');
    }

    // Imagenes de posts: read si autor o amigo del autor (mismo nivel que el post).
    // Path: posts/{authorUserId}/{filename}.
    match /posts/{userId}/{allPaths=**} {
      allow read: if request.auth != null && (
        request.auth.uid == userId ||
        firestore.exists(/databases/(default)/documents/users/$(request.auth.uid)/friends/$(userId))
      );
      allow write: if request.auth != null
        && request.auth.uid == userId
        && request.resource.size < 5 * 1024 * 1024
        && request.resource.contentType.matches('image/.*');
    }

    // Default deny
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
