---
interface Props {
  title: string;
}

const { title } = Astro.props;
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta
      name="description"
      content="GoroReads - Gestiona tus listas de lectura de manga, manhwa y más"
    />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />

    <!-- PWA: manifest + theme + iOS -->
    <link rel="manifest" href="/manifest.webmanifest" />
    <meta name="theme-color" content="#8b5cf6" />
    <meta name="apple-mobile-web-app-capable" content="yes" />
    <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent" />
    <meta name="apple-mobile-web-app-title" content="GoroReads" />
    <link rel="apple-touch-icon" href="/icons/apple-touch-icon.png" />

    <title>{title} | GoroReads</title>

    <script>
      // Registro del Service Worker. Falla silenciosamente en dev (no hay /sw.js)
      // y se activa en produccion una vez el build genera el archivo.
      if ('serviceWorker' in navigator) {
        window.addEventListener('load', () => {
          navigator.serviceWorker.register('/sw.js').catch(() => {});
        });
      }
    </script>
  </head>
  <body>
    <slot />
  </body>
</html>

<style is:global>
  @import "../styles/global.css";
</style>
